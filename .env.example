# ── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── Application ───────────────────────────────────────────────────────────────
APP_URL=https://trustpages.fly.dev
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# ── LLM ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_live_...
# Set to your verified Resend domain once DNS records are confirmed.
# Dev/sandbox default:  TrustPages <onboarding@resend.dev>
# Production example:   TrustPages <noreply@mail.yourdomain.com>
RESEND_FROM_EMAIL=TrustPages <onboarding@resend.dev>

# ── Billing (Paddle) ───────────────────────────────────────────────────────────
# Server-side API key (Paddle > Developer tools > Authentication) — keep secret.
PADDLE_API_KEY=pdl_...
# Client-side token (Paddle > Developer tools > Authentication) — safe to expose
# in frontend code, used by Paddle.js on the checkout page.
PADDLE_CLIENT_TOKEN=live_...
# Webhook signing secret (Paddle > Developer tools > Notifications > your endpoint).
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...
PADDLE_PRICE_ID_GROWTH=pri_...
# "sandbox" while testing, "production" once live.
PADDLE_ENVIRONMENT=sandbox

# ── Observability (optional) ──────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
