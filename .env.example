# ── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── Application ───────────────────────────────────────────────────────────────
APP_URL=https://trustpages.fly.dev
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# ── LLM ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_live_...
# Set to your verified Resend domain once DNS records are confirmed.
# Dev/sandbox default:  TrustPages <onboarding@resend.dev>
# Production example:   TrustPages <noreply@mail.yourdomain.com>
RESEND_FROM_EMAIL=TrustPages <onboarding@resend.dev>

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_GROWTH=price_...

# ── Observability (optional) ──────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
